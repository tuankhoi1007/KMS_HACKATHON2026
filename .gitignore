# ==========================================
# 1. BIẾN MÔI TRƯỜNG & BẢO MẬT (QUAN TRỌNG NHẤT)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ==========================================
# 2. BACKEND (Python / FastAPI)
# ==========================================
# Thư mục môi trường ảo (Virtual Environment)
venv/
env/
.venv/
env.bak/
venv.bak/

# Cache và file biên dịch của Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Database local (Nếu có dùng SQLite để test)
*.sqlite3
*.db

# Các công cụ khác của Python
.mypy_cache/
.ruff_cache/
pip-log.txt

# ==========================================
# 3. FRONTEND (React / Node.js)
# ==========================================
# Thư mục chứa thư viện khổng lồ của Node (Bắt buộc phải ignore)
node_modules/
jspm_packages/

# Thư mục build (Code đã đóng gói, không cần đẩy lên Git)
build/
dist/
out/

# Log lỗi của NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# 4. HỆ ĐIỀU HÀNH & EDITOR (IDE)
# ==========================================
# Windows & macOS hệ thống
.DS_Store
Thumbs.db

# Cấu hình IDE (VS Code, PyCharm, WebStorm...)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln